# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/virtualfit

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# App
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Try-on server (Colab tunnel URL). Run colab/idm_vton_server.ipynb for the
# high-quality IDM-VTON engine (recommended), or colab/catvton_server.ipynb for
# the lighter CatVTON fallback — both expose the same /tryon contract and publish
# to the same discovery store below. The URL changes every Colab session, so
# leave this blank — it is auto-discovered. (Override via POST /api/tryon/server.)
TRYON_API_URL=

# Auto-discovery store: the Colab notebook PUTs its current tunnel URL here on
# startup; the backend GETs it when a try-on runs. Set once, never touch again.
TRYON_DISCOVERY_URL=https://jsonblob.com/api/jsonBlob/019ef86e-3c96-7d7f-8d36-e14639cf7546
